{
  "name": "nmrium-desktop",
  "version": "2.3.0",
  "description": "NMRium NMR spectrum viewer — desktop app",
  "homepage": "https://github.com/cheminfo/nmrium",
  "author": {
    "name": "David",
    "email": "david@katalystnord.com"
  },
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "dev:renderer": "vite build --watch",
    "build:nmrium": "bash scripts/build-nmrium.sh",
    "build:renderer": "vite build",
    "generate-icons": "electron scripts/generate-icons.cjs --no-sandbox",
    "build": "npm run build:nmrium && npm run generate-icons && npm run build:renderer && electron-builder && npm run build:samples",
    "dist": "npm run build:nmrium && npm run generate-icons && npm run build:renderer && electron-builder --publish never && npm run build:samples",
    "pack": "npm run build:nmrium && npm run generate-icons && npm run build:renderer && electron-builder --dir",
    "update-nmrium": "bash scripts/update-nmrium.sh",
    "build:samples": "npm run build:samples-archive && npm run build:samples-deb",
    "build:samples-archive": "bash scripts/build-samples-archive.sh",
    "build:samples-deb": "bash scripts/build-samples-deb.sh"
  },
  "devDependencies": {
    "@blueprintjs/core": "^6.16.0",
    "@blueprintjs/icons": "^6.11.0",
    "@blueprintjs/select": "^6.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "modern-normalize": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-science": "^20.2.0",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.nmrium.desktop",
    "productName": "NMRium Desktop",
    "asar": true,
    "compression": "normal",
    "electronLanguages": ["en-US"],
    "directories": {
      "buildResources": "build"
    },
    "afterPack": "./scripts/appimage-wrap.cjs",
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "renderer/dist",
        "to": "renderer-dist"
      },
      {
        "from": "nmrium/src/demo/samples.json",
        "to": "samples-catalog.json"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "fileAssociations": [
      {
        "ext": "dx",
        "name": "JCAMP-DX Spectrum",
        "description": "JCAMP-DX NMR spectrum file",
        "mimeType": "chemical/x-jcamp-dx",
        "role": "Editor"
      },
      {
        "ext": "jdx",
        "name": "JCAMP-DX Spectrum",
        "description": "JCAMP-DX NMR spectrum file",
        "mimeType": "chemical/x-jcamp-dx",
        "role": "Editor"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "Science;Education",
      "desktop": {
        "StartupWMClass": "nmrium-desktop"
      }
    },
    "deb": {
      "fpm": ["--deb-suggests=nmrium-desktop-samples"]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.education"
    }
  }
}
